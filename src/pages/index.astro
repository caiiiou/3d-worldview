<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>World View</title>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://nominatim.openstreetmap.org" />
    <link rel="preload" href="https://cesium.com/downloads/cesiumjs/releases/1.119/Build/Cesium/Cesium.js" as="script" />
    <link href="https://cesium.com/downloads/cesiumjs/releases/1.119/Build/Cesium/Widgets/widgets.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body class="mode-normal loc-expanded">

<div id="cesiumContainer"></div>
<!-- Edge text -->
<div class="edge-text-left">COLL: <span id="edge-time-l"></span></div>
<div class="edge-text-right">GMA: 68.0</div>

<!-- Compass -->

<div id="compass">
    <svg viewBox="0 0 50 50">
        <circle cx="25" cy="25" r="22" stroke="rgba(127,219,202,0.2)" stroke-width="0.5" fill="none"/>
        <polygon id="compass-needle" points="25,6 27,22 25,20 23,22" fill="rgba(127,219,202,0.5)"/>
        <circle cx="25" cy="25" r="2" fill="rgba(127,219,202,0.3)"/>
        <text x="25" y="5" text-anchor="middle" fill="rgba(127,219,202,0.4)" font-size="4" font-family="Fira Code">N</text>
    </svg>
</div>

<div id="vignette"></div>

<!-- HUD Top Left -->
<div id="hud-topleft" class="hud">
    <div class="brand">WORLDVIEW</div>
    <div class="classification">TOP SECRET // SI-TK // NOFORN</div>
    <div class="ops-id">KH11-4084 OPS-4114</div>
    <div class="mode-label" id="mode-label">NORMAL</div>
</div>

<!-- HUD Bottom Left -->
<div id="hud-bottomleft" class="hud">
    <div class="coord-bracket">&#x2514; MGRS</div>
    <div class="coord-value" id="coord-mgrs">54S 9885 5626</div>
    <div class="coord-dms" id="coord-dms">35&deg;37'36.11"N 139&deg;53'06.00"E</div>
    <div class="coord-value" id="coord-alt" style="margin-top:4px;">ALT: 0.2 KM</div>
    <div class="coord-value" id="coord-speed" style="font-size:10px;color:#4a6670;">HDG: 0.0&deg;</div>
</div>


<!-- Top center stack: Style Presets + HUD toggle -->
<div id="top-stack">
    <div id="hud-bottom" class="hud hud-interactive">
        <div class="hud-label">STYLE PRESETS</div>
        <div id="style-presets">
            <button class="style-btn active" data-mode="normal"><span class="key-hint">1</span>NORMAL</button>
            <button class="style-btn" data-mode="crt"><span class="key-hint">2</span>CRT</button>
            <button class="style-btn" data-mode="nightvision"><span class="key-hint">3</span>NIGHT VISION</button>
            <button class="style-btn" data-mode="flir"><span class="key-hint">4</span>FLIR</button>
            <button class="style-btn" data-mode="anime"><span class="key-hint">5</span>ANIME</button>
        </div>
    </div>
</div>

<!-- Bottom: Location -->
<div id="loc-wrapper">
<button id="loc-toggle">LOCATIONS <span id="loc-arrow">&#x25B2;</span><span class="enter-hint">ENTER</span></button>
<div id="location-panel">
    <div class="loc-columns">
        <div class="loc-col">
            <div class="loc-section-label">LANDMARKS</div>
            <div id="loc-landmarks"></div>
        </div>
        <div class="loc-col">
            <div class="loc-section-label">CITIES</div>
            <div id="loc-cities"></div>
        </div>
    </div>
    <div class="loc-row">
        <div style="position:relative;">
            <input type="text" id="loc-input" placeholder="Search any location..." autocomplete="off">
            <span class="key-hint" style="position:absolute;top:50%;right:6px;transform:translateY(-50%);">SPACE</span>
            <div id="loc-autocomplete"></div>
        </div>
        <button id="loc-go" onclick="flyToLocation()">GO</button>
    </div>
    <div class="loc-info">
        Location: <span id="loc-name">TOKYO DISNEYSEA</span> | <span id="loc-landmark">LANDMARK</span>
    </div>
</div>
</div>

<!-- Measure overlay -->
<div id="measure-info"></div>

<!-- Loading bar -->
<div id="load-bar"></div>


    <script is:inline src="https://cesium.com/downloads/cesiumjs/releases/1.119/Build/Cesium/Cesium.js"></script>
    <script src="../scripts/worldview.ts"></script>
  </body>
</html>
